{
  "info": {
    "name": "SkyState API",
    "description": "SkyState - Hosted state management service for connected applications.\n\n## Authentication\n\nThis collection uses Postman's built-in OAuth 2.0 flow with GitHub.\n\n### Setup (one-time)\n\n1. In your GitHub OAuth App settings, add this callback URL:\n   `https://oauth.pstmn.io/v1/callback`\n2. Set the `githubClientId` and `githubClientSecret` collection variables\n\n### Getting a token\n\n1. Click the **Authorization** tab on this collection\n2. Scroll down and click **Get New Access Token**\n3. Authenticate with GitHub in the popup\n4. Click **Use Token** — Postman auto-attaches it to all requests\n\nThe token is a GitHub OAuth access token sent as a Bearer token. The API validates it directly against GitHub's `/user` endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "grant_type",
        "value": "authorization_code",
        "type": "string"
      },
      {
        "key": "authUrl",
        "value": "https://github.com/login/oauth/authorize",
        "type": "string"
      },
      {
        "key": "accessTokenUrl",
        "value": "https://github.com/login/oauth/access_token",
        "type": "string"
      },
      {
        "key": "clientId",
        "value": "{{githubClientId}}",
        "type": "string"
      },
      {
        "key": "clientSecret",
        "value": "{{githubClientSecret}}",
        "type": "string"
      },
      {
        "key": "redirect_uri",
        "value": "https://oauth.pstmn.io/v1/callback",
        "type": "string"
      },
      {
        "key": "scope",
        "value": "",
        "type": "string"
      },
      {
        "key": "tokenName",
        "value": "GitHub Token",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5149",
      "type": "string"
    },
    {
      "key": "githubClientId",
      "value": "",
      "type": "string"
    },
    {
      "key": "githubClientSecret",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "environmentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "projectStateId",
      "value": "",
      "type": "string"
    },
    {
      "key": "invoiceId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "description": "Current user profile management",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"My Display Name\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "description": "Project CRUD operations",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Get Project by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/by-slug/my-project",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "by-slug", "my-project"]
            }
          }
        },
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('projectId', json.projectId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Project\",\n  \"slug\": \"my-project\",\n  \"apiKeyHash\": \"a]!d7$kP2m#Qx9Lw\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            },
            "description": "Creates a new project. On success, auto-sets the `projectId` collection variable."
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"apiKeyHash\": \"b]!e8$lQ3n#Ry0Mx\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}"]
            }
          }
        }
      ]
    },
