    {
      "name": "States",
      "description": "Project state versioning and management",
      "item": [
        {
          "name": "List States",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/environments/{{environmentId}}/states",
              "host": ["{{baseUrl}}"],
              "path": ["environments", "{{environmentId}}", "states"]
            }
          }
        },
        {
          "name": "Get Latest State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/environments/{{environmentId}}/states/latest",
              "host": ["{{baseUrl}}"],
              "path": ["environments", "{{environmentId}}", "states", "latest"]
            }
          }
        },
        {
          "name": "Get State by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/states/{{projectStateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["states", "{{projectStateId}}"]
            }
          }
        },
        {
          "name": "Create State",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('projectStateId', json.projectStateId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"major\": 1,\n  \"minor\": 0,\n  \"patch\": 0,\n  \"state\": \"{\\\"featureFlags\\\":{\\\"darkMode\\\":true,\\\"betaAccess\\\":false},\\\"settings\\\":{\\\"maxRetries\\\":3}}\",\n  \"comment\": \"Initial state\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/environments/{{environmentId}}/states",
              "host": ["{{baseUrl}}"],
              "path": ["environments", "{{environmentId}}", "states"]
            },
            "description": "Creates a new state version. On success, auto-sets the `projectStateId` collection variable. Returns 403 if free tier limits exceeded."
          }
        },
        {
          "name": "Rollback State",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/environments/{{environmentId}}/states/rollback/{{projectStateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["environments", "{{environmentId}}", "states", "rollback", "{{projectStateId}}"]
            },
            "description": "Rolls back to a target state version by creating a new version entry with the same content."
          }
        },
        {
          "name": "Public Read State",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "If-None-Match",
                "value": "",
                "description": "ETag from previous response for conditional request",
                "disabled": true
              },
              {
                "key": "If-Modified-Since",
                "value": "",
                "description": "Timestamp from previous response for conditional request",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/state/my-project/prod",
              "host": ["{{baseUrl}}"],
              "path": ["state", "my-project", "prod"]
            },
            "description": "CDN-friendly public read endpoint. No authentication required. Supports ETag and If-Modified-Since for caching. Returns 304 Not Modified when content hasn't changed."
          }
        }
      ]
    },
