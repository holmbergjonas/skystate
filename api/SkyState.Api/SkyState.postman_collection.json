          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "description": "External service webhooks",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Stripe-Signature",
                "value": "",
                "description": "Stripe webhook signature (required)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhooks/stripe",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks", "stripe"]
            },
            "description": "Receives Stripe webhook events. Uses Stripe-Signature header for verification instead of JWT auth. Typically called by Stripe, not manually."
          }
        }
      ]
    }
  ]
