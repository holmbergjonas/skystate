            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/environments",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "environments"]
            },
            "description": "Creates a new environment. On success, auto-sets the `environmentId` collection variable."
          }
        },
        {
          "name": "Update Environment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
