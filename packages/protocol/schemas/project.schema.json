{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skystate.io/schemas/project.schema.json",
  "title": "Project",
  "description": "Project resource returned by GET /projects and GET /projects/{id}.",
  "type": "object",
  "properties": {
    "projectId":  { "type": "string", "format": "uuid" },
    "userId":     { "type": "string", "format": "uuid" },
    "name":       { "type": "string" },
    "slug":       { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "apiKeyHash": { "type": "string" },
    "createdAt":  { "type": "string", "format": "date-time" },
    "updatedAt":  { "type": "string", "format": "date-time" }
  },
  "required": ["projectId", "userId", "name", "slug", "apiKeyHash", "createdAt", "updatedAt"],
  "additionalProperties": false
}
